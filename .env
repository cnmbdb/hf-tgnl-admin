# ================== 数据库配置 ==================
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=tgnl

# ================== 应用基础配置 ==================
# Nuxt / 后台访问路径：最终访问地址类似 http(s)://域名:端口/admin
APP_BASE_PATH=/admin
PORT=3000
APP_HOST=app

# 端口绑定 IP（安全相关）
# 生产环境：建议 127.0.0.1（只本机访问，由 Nginx 回源）
# 如需临时对外暴露端口（不推荐），可改为 0.0.0.0
BIND_IP=127.0.0.1

# 运行环境
NODE_ENV=production

# ================== 域名 / 访问控制 ==================
# 绑定后台域名（例如 admin.example.com）
DOMAIN_NAME=tg-admin-7a3b.test
# 是否启用域名校验
ENFORCE_HOST_CHECK=false
# 是否允许通过 IP+端口直接访问
ALLOW_IP_ACCESS=true
# 允许的额外 Host 白名单
ALLOWED_HOSTS=localhost,127.0.0.1

# ================== WordPress 授权相关 ==================
WORDPRESS_URL=https://hfz.pw
WORDPRESS_USERNAME=123@qq.com
WORDPRESS_APP_PASSWORD=5HfTRWJXQOjlcYYSxc0Ts6xo
WORDPRESS_PRODUCT_ID=2061
# 生产环境不允许绕过授权
LICENSE_DEV_BYPASS=false

# ================== 后台默认管理员（首次初始化用） ==================
DEV_ADMIN_USER=admin
DEV_ADMIN_PASS=admin123
DEV_ADMIN_EMAIL=admin@example.com
# 生产建议禁用开发登录
DEV_LOGIN_ENABLED=false

# ================== Bot / Webhook 相关 ==================
# 机器人 Webhook 端口（容器内），默认 8443
BOT_WEBHOOK_PORT=8443
BOT_WEBHOOK_PATH=/webhook
BOT_WEBHOOK_URL=
# 首次部署时自动把 nl-2333/config.txt 里的 bot_notify_url 从 localhost 换成服务器公网 IP
BOT_NOTIFY_URL_AUTO_IP=true

# ================== 其他可选配置 ==================
TZ=Asia/Shanghai
NUXT_PUBLIC_SITE_TITLE=cahbcjuzuakj
NUXT_PUBLIC_ROBOTS_INDEX=false

# 应用版本（仅用于前端显示/检查更新）
APP_VERSION=2026.2.22

